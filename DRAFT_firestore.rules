rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Funções auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Reports e Sectors
    match /reports/{dateId} {
      allow read: if true; // Leitura pública para visualização do dashboard
      
      match /sectors/{sectorId} {
        allow read: if true;
        allow write: if isSignedIn() || true; // Permitindo escrita para o demo, mas idealmente seria restrito
      }
    }
  }
}
